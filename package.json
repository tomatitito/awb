{
  "name": "awb",
  "version": "0.1.0",
  "description": "Agentic workbench built on the tk-style ticket viewer UI",
  "type": "module",
  "packageManager": "bun@1.2.18",
  "bin": {
    "awb": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "node scripts/fix-vite-esbuild.mjs",
    "build": "vite build && tsc -p tsconfig.json",
    "build:web": "vite build",
    "build:node": "tsc -p tsconfig.json",
    "check": "biome check src/ tests/",
    "check:fix": "biome check src/ tests/ --write",
    "dev": "bun src/cli.ts --dev",
    "start": "bun dist/cli.js"
  },
  "keywords": [
    "tickets",
    "kanban",
    "graph",
    "cli",
    "viewer",
    "agent",
    "workbench"
  ],
  "license": "MIT",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "0.67.6",
    "cytoscape": "3.33.2",
    "express": "5.2.1",
    "fast-glob": "3.3.3",
    "gray-matter": "4.0.3",
    "open": "11.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "10.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "esbuild": "0.25.12",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite": "6.4.2"
  }
}
